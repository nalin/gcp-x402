# Base URL of the gcp.sh proxy you deployed.
PROXY_URL=https://gcp.sh

# Refuse to auto-pay more than this (USD) for a single query.
MAX_PAYMENT_USD=1.00

# ─── Wallet (optional) ───────────────────────────────────────────────────────
# By default the server GENERATES a wallet on first run, PER PROJECT, saved to
# ./.gcp-sh/wallet.json in the directory it's launched from — you just fund the
# printed address with Base USDC. Each project gets its own wallet.
# Override only if you want to bring your own key or relocate the keystore:
# WALLET_PRIVATE_KEY=0x...
# WALLET_FILE=/abs/path/wallet.json   # absolute path = share one wallet across projects
