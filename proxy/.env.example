# ─── BigQuery (the billing project that runs jobs) ───────────────────────────
# A GCP project WITH a billing account. This is what pays Google for query
# compute; you resell that compute over x402.
GCP_PROJECT_ID=your-billing-project

# Service-account credentials as inline JSON (recommended on Vercel). The SA
# needs roles/bigquery.jobUser on this project and nothing more.
# Alternatively, unset this and set GOOGLE_APPLICATION_CREDENTIALS to a file path.
GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Comma-separated projects whose datasets may be queried. Keep this tight.
ALLOWED_PROJECTS=bigquery-public-data

# Optional guards
BQ_LOCATION=US
MAX_BYTES_PER_QUERY=109951162777600   # 100 TiB
MAX_INLINE_ROWS=10000
QUERY_TIMEOUT_MS=60000
# Headroom on the per-query byte cap so dry-run/actual rounding deltas don't
# spuriously fail jobs. 1.2 = allow 20% over the quote before hard-failing.
BYTE_CAP_BUFFER=1.2

# ─── Pricing ─────────────────────────────────────────────────────────────────
# Defaults: ~$6.25/TiB, 2x markup, $0.002 floor, 10 MB/table minimum.
# USD_PER_BYTE=0.0000000000056843418860808015
PRICE_MARKUP=2.0
PRICE_FLOOR_USD=0.002

# ─── x402 settlement ─────────────────────────────────────────────────────────
# Use "base-sepolia" (testnet, no real money) until you're ready for mainnet.
X402_NETWORK=base-sepolia

# Address that receives USDC for queries.
PAY_TO_ADDRESS=0xYourReceivingWalletAddress

# Facilitator that verifies + settles payments. The x402.org public facilitator
# works for base-sepolia; for Base mainnet use the Coinbase CDP facilitator.
FACILITATOR_URL=https://x402.org/facilitator
# FACILITATOR_API_KEY=   # set if your facilitator requires a bearer token

QUOTE_TTL_SECONDS=60

# ─── Quote signing ───────────────────────────────────────────────────────────
# Any long random secret. Generate with: openssl rand -base64 48
QUOTE_SECRET=replace-with-a-long-random-secret
